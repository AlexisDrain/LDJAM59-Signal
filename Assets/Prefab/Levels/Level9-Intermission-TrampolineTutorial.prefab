  m_EditorClassIdentifier: '::'
  levelStory: '<color=#00B4FF>Intermission</color>


    Due to a sudden rule change,
    the association football league has changed the goal shape. You can now double-jump
    using a trampoline to reach the highest row.


    Press <color=#00B4FF>SPACE</color>
    in mid-air to jump again!'
  tallLevel: 1
  tutorialDoubleJump: 1
  removeColorGrid: 0
